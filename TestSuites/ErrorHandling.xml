<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite parallel="tests" name="Suite">
<!-- parallel="tests" used to run the all tests parallely to save the execution time and instead running the tests sequence wise-->
  <test thread-count="5" name="Main project Test">
  
    <classes>
      <class name="Selenium.SeleniumAlltestngandPom.SubmitOrder"/>
    </classes>
  
  </test> <!-- Test 1-->
  
  <test name="Error Validations Test">
  	
  	<classes>
  		<class name="Selenium.SeleniumAlltestngandPom.ErrorValidation"/>
  	</classes>
  
  </test> <!-- Test 2-->
</suite> <!-- Suite -->	
